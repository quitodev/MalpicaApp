<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".compras.IngresarCompras"
    android:background="#B3000000">

    <ScrollView
        android:id="@+id/scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_alignParentStart="true"
        android:layout_alignParentLeft="true"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_alignParentRight="true"
        android:layout_marginStart="0dp"
        android:layout_marginLeft="0dp"
        android:layout_marginTop="0dp"
        android:layout_marginEnd="0dp"
        android:layout_marginRight="0dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textIngresar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_alignParentLeft="true"
                android:layout_alignParentTop="true"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:layout_marginStart="0dp"
                android:layout_marginLeft="0dp"
                android:layout_marginTop="30dp"
                android:layout_marginEnd="0dp"
                android:layout_marginRight="0dp"
                android:fontFamily="sans-serif-light"
                android:gravity="center_horizontal"
                android:text="@string/compras_ingresar"
                android:textColor="@color/colorAccent"
                android:textSize="24sp" />

            <TextView
                android:id="@+id/textFechaCompra"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/textIngresar"
                android:layout_alignParentStart="true"
                android:layout_alignParentLeft="true"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:layout_marginStart="54dp"
                android:layout_marginLeft="54dp"
                android:layout_marginTop="35dp"
                android:layout_marginEnd="0dp"
                android:layout_marginRight="0dp"
                android:fontFamily="sans-serif-light"
                android:text="@string/fecha_compra"
                android:textColor="@color/colorAccent"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/editFechaCompra"
                android:layout_width="310dp"
                android:layout_height="42dp"
                android:layout_below="@+id/textFechaCompra"
                android:layout_alignParentStart="true"
                android:layout_alignParentLeft="true"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:layout_marginStart="50dp"
                android:layout_marginLeft="50dp"
                android:layout_marginTop="0dp"
                android:layout_marginEnd="51dp"
                android:layout_marginRight="51dp"
                android:drawablePadding="5dp"
                android:ems="10"
                android:fontFamily="sans-serif-light"
                android:hint="@string/ingresar_fecha"
                android:inputType="textPersonName"
                android:maxLength="10"
                android:text=""
                android:textColor="@color/colorText"
                android:textColorHint="#919191"
                android:textColorLink="@color/colorAccent"
                android:textSize="18sp"
                tools:ignore="Autofill" />

            <TextView
                android:id="@+id/textNroFactura"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/editFechaCompra"
                android:layout_alignParentStart="true"
                android:layout_alignParentLeft="true"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:layout_marginStart="54dp"
                android:layout_marginLeft="54dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="0dp"
                android:layout_marginRight="0dp"
                android:fontFamily="sans-serif-light"
                android:text="@string/nro_factura"
                android:textColor="@color/colorAccent"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/editNroFactura"
                android:layout_width="310dp"
                android:layout_height="42dp"
                android:layout_below="@+id/textNroFactura"
                android:layout_alignParentStart="true"
                android:layout_alignParentLeft="true"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:layout_marginStart="50dp"
                android:layout_marginLeft="50dp"
                android:layout_marginTop="0dp"
                android:layout_marginEnd="51dp"
                android:layout_marginRight="51dp"
                android:drawablePadding="5dp"
                android:ems="10"
                android:fontFamily="sans-serif-light"
                android:hint="@string/ingresar_nro_factura"
                android:inputType="textPersonName"
                android:maxLength="15"
                android:text=""
                android:textColor="@color/colorText"
                android:textColorHint="#919191"
                android:textColorLink="@color/colorAccent"
                android:textSize="18sp"
                tools:ignore="Autofill" />

            <TextView
                android:id="@+id/textDatosProveedor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/editNroFactura"
                android:layout_alignParentStart="true"
                android:layout_alignParentLeft="true"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:layout_marginStart="0dp"
                android:layout_marginLeft="0dp"
                android:layout_marginTop="35dp"
                android:layout_marginEnd="0dp"
                android:layout_marginRight="0dp"
                android:gravity="center"
                android:fontFamily="sans-serif-light"
                android:text="@string/datos_proveedor"
                android:textColor="@color/colorText"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/textCodigoProv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/textDatosProveedor"
                android:layout_alignParentStart="true"
                android:layout_alignParentLeft="true"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:layout_marginStart="54dp"
                android:layout_marginLeft="54dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="0dp"
                android:layout_marginRight="0dp"
                android:fontFamily="sans-serif-light"
                android:text="@string/codigo"
                android:textColor="@color/colorAccent"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/editCodigoProv"
                android:layout_width="310dp"
                android:layout_height="42dp"
                android:layout_below="@+id/textCodigoProv"
                android:layout_alignParentStart="true"
                android:layout_alignParentLeft="true"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:layout_marginStart="50dp"
                android:layout_marginLeft="50dp"
                android:layout_marginEnd="51dp"
                android:layout_marginRight="51dp"
                android:drawablePadding="5dp"
                android:ems="10"
                android:fontFamily="sans-serif-light"
                android:hint="@string/ingresar_codigo"
                android:inputType="textPersonName"
                android:maxLength="12"
                android:text=""
                android:textColorHint="#919191"
                android:textColor="@color/colorText"
                android:textColorLink="@color/colorAccent"
                android:textSize="18sp"
                tools:ignore="Autofill" />

            <TextView
                android:id="@+id/textRazonSocialProv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/editCodigoProv"
                android:layout_alignParentStart="true"
                android:layout_alignParentLeft="true"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:layout_marginStart="54dp"
                android:layout_marginLeft="54dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="0dp"
                android:layout_marginRight="0dp"
                android:fontFamily="sans-serif-light"
                android:text="@string/razon_social"
                android:textColor="@color/colorAccent"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/editRazonSocialProv"
                android:layout_width="310dp"
                android:layout_height="42dp"
                android:layout_below="@+id/textRazonSocialProv"
                android:layout_alignParentStart="true"
                android:layout_alignParentLeft="true"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:layout_marginStart="50dp"
                android:layout_marginLeft="50dp"
                android:layout_marginEnd="51dp"
                android:layout_marginRight="51dp"
                android:drawablePadding="5dp"
                android:ems="10"
                android:fontFamily="sans-serif-light"
                android:hint="@string/ingresar_razon_social"
                android:inputType="textPersonName"
                android:maxLength="50"
                android:text=""
                android:textColorHint="#919191"
                android:textColor="@color/colorText"
                android:textColorLink="@color/colorAccent"
                android:textSize="18sp"
                tools:ignore="Autofill" />

            <TextView
                android:id="@+id/textCondicionProv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/editRazonSocialProv"
                android:layout_alignParentStart="true"
                android:layout_alignParentLeft="true"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:layout_marginStart="54dp"
                android:layout_marginLeft="54dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="0dp"
                android:layout_marginRight="0dp"
                android:fontFamily="sans-serif-light"
                android:text="@string/condicion"
                android:textColor="@color/colorAccent"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/editCondicionProv"
                android:layout_width="310dp"
                android:layout_height="42dp"
                android:layout_below="@+id/textCondicionProv"
                android:layout_alignParentStart="true"
                android:layout_alignParentLeft="true"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:layout_marginStart="50dp"
                android:layout_marginLeft="50dp"
                android:layout_marginEnd="51dp"
                android:layout_marginRight="51dp"
                android:drawablePadding="5dp"
                android:ems="10"
                android:fontFamily="sans-serif-light"
                android:hint="@string/ingresar_condicion"
                android:inputType="textPersonName"
                android:maxLength="2"
                android:text=""
                android:textColorHint="#919191"
                android:textColor="@color/colorText"
                android:textColorLink="@color/colorAccent"
                android:textSize="18sp"
                tools:ignore="Autofill" />

            <TextView
                android:id="@+id/textDatosProducto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/editCondicionProv"
                android:layout_alignParentStart="true"
                android:layout_alignParentLeft="true"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:layout_marginStart="0dp"
                android:layout_marginLeft="0dp"
                android:layout_marginTop="35dp"
                android:layout_marginEnd="0dp"
                android:layout_marginRight="0dp"
                android:gravity="center"
                android:fontFamily="sans-serif-light"
                android:text="@string/datos_producto"
                android:textColor="@color/colorText"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/textCodigoProd"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/textDatosProducto"
                android:layout_alignParentStart="true"
                android:layout_alignParentLeft="true"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:layout_marginStart="54dp"
                android:layout_marginLeft="54dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="0dp"
                android:layout_marginRight="0dp"
                android:fontFamily="sans-serif-light"
                android:text="@string/codigo"
                android:textColor="@color/colorAccent"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/editCodigoProd"
                android:layout_width="310dp"
                android:layout_height="42dp"
                android:layout_below="@+id/textCodigoProd"
                android:layout_alignParentStart="true"
                android:layout_alignParentLeft="true"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:layout_marginStart="50dp"
                android:layout_marginLeft="50dp"
                android:layout_marginEnd="51dp"
                android:layout_marginRight="51dp"
                android:drawablePadding="5dp"
                android:ems="10"
                android:fontFamily="sans-serif-light"
                android:hint="@string/ingresar_codigo"
                android:inputType="textPersonName"
                android:maxLength="12"
                android:text=""
                android:textColorHint="#919191"
                android:textColor="@color/colorText"
                android:textColorLink="@color/colorAccent"
                android:textSize="18sp"
                tools:ignore="Autofill" />

            <TextView
                android:id="@+id/textDescripcionProd"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/editCodigoProd"
                android:layout_alignParentStart="true"
                android:layout_alignParentLeft="true"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:layout_marginStart="54dp"
                android:layout_marginLeft="54dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="0dp"
                android:layout_marginRight="0dp"
                android:fontFamily="sans-serif-light"
                android:text="@string/descripcion"
                android:textColor="@color/colorAccent"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/editDescripcionProd"
                android:layout_width="310dp"
                android:layout_height="42dp"
                android:layout_below="@+id/textDescripcionProd"
                android:layout_alignParentStart="true"
                android:layout_alignParentLeft="true"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:layout_marginStart="50dp"
                android:layout_marginLeft="50dp"
                android:layout_marginEnd="51dp"
                android:layout_marginRight="51dp"
                android:drawablePadding="5dp"
                android:ems="10"
                android:fontFamily="sans-serif-light"
                android:hint="@string/ingresar_descripcion"
                android:inputType="textPersonName"
                android:maxLength="50"
                android:text=""
                android:textColorHint="#919191"
                android:textColor="@color/colorText"
                android:textColorLink="@color/colorAccent"
                android:textSize="18sp"
                tools:ignore="Autofill" />

            <TextView
                android:id="@+id/textCantidad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/editDescripcionProd"
                android:layout_alignParentStart="true"
                android:layout_alignParentLeft="true"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:layout_marginStart="54dp"
                android:layout_marginLeft="54dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="0dp"
                android:layout_marginRight="0dp"
                android:fontFamily="sans-serif-light"
                android:text="@string/cantidad"
                android:textColor="@color/colorAccent"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/editCantidad"
                android:layout_width="310dp"
                android:layout_height="42dp"
                android:layout_below="@+id/textCantidad"
                android:layout_alignParentStart="true"
                android:layout_alignParentLeft="true"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:layout_marginStart="50dp"
                android:layout_marginLeft="50dp"
                android:layout_marginEnd="51dp"
                android:layout_marginRight="51dp"
                android:drawablePadding="5dp"
                android:ems="10"
                android:fontFamily="sans-serif-light"
                android:hint="@string/ingresar_cantidad"
                android:inputType="number"
                android:maxLength="7"
                android:text="@string/ingresar_cantidad"
                android:textColorHint="#919191"
                android:textColor="@color/colorText"
                android:textColorLink="@color/colorAccent"
                android:textSize="18sp"
                tools:ignore="Autofill" />

            <TextView
                android:id="@+id/textPrecioUnit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/editCantidad"
                android:layout_alignParentStart="true"
                android:layout_alignParentLeft="true"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:layout_marginStart="54dp"
                android:layout_marginLeft="54dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="0dp"
                android:layout_marginRight="0dp"
                android:fontFamily="sans-serif-light"
                android:text="@string/precio_unit"
                android:textColor="@color/colorAccent"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/editPrecioUnit"
                android:layout_width="310dp"
                android:layout_height="42dp"
                android:layout_below="@+id/textPrecioUnit"
                android:layout_alignParentStart="true"
                android:layout_alignParentLeft="true"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:layout_marginStart="50dp"
                android:layout_marginLeft="50dp"
                android:layout_marginEnd="51dp"
                android:layout_marginRight="51dp"
                android:drawablePadding="5dp"
                android:ems="10"
                android:fontFamily="sans-serif-light"
                android:hint="@string/ingresar_precio_unit"
                android:inputType="numberDecimal"
                android:maxLength="10"
                android:text="@string/ingresar_precio_unit"
                android:textColorHint="#919191"
                android:textColor="@color/colorText"
                android:textColorLink="@color/colorAccent"
                android:textSize="18sp"
                tools:ignore="Autofill" />

            <TextView
                android:id="@+id/textImpuestos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/editPrecioUnit"
                android:layout_alignParentStart="true"
                android:layout_alignParentLeft="true"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:layout_marginStart="54dp"
                android:layout_marginLeft="54dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="0dp"
                android:layout_marginRight="0dp"
                android:fontFamily="sans-serif-light"
                android:text="@string/impuestos"
                android:textColor="@color/colorAccent"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/editImpuestos"
                android:layout_width="310dp"
                android:layout_height="42dp"
                android:layout_below="@+id/textImpuestos"
                android:layout_alignParentStart="true"
                android:layout_alignParentLeft="true"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:layout_marginStart="50dp"
                android:layout_marginLeft="50dp"
                android:layout_marginEnd="51dp"
                android:layout_marginRight="51dp"
                android:drawablePadding="5dp"
                android:ems="10"
                android:fontFamily="sans-serif-light"
                android:hint="@string/ingresar_impuestos"
                android:inputType="numberDecimal"
                android:maxLength="10"
                android:text="@string/ingresar_impuestos"
                android:textColorHint="#919191"
                android:textColor="@color/colorText"
                android:textColorLink="@color/colorAccent"
                android:textSize="18sp"
                tools:ignore="Autofill" />

            <TextView
                android:id="@+id/textPrecioTotal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/editImpuestos"
                android:layout_alignParentStart="true"
                android:layout_alignParentLeft="true"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:layout_marginStart="54dp"
                android:layout_marginLeft="54dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="0dp"
                android:layout_marginRight="0dp"
                android:fontFamily="sans-serif-light"
                android:text="@string/precio_total"
                android:textColor="@color/colorAccent"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/editPrecioTotal"
                android:layout_width="310dp"
                android:layout_height="42dp"
                android:layout_below="@+id/textPrecioTotal"
                android:layout_alignParentStart="true"
                android:layout_alignParentLeft="true"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:layout_marginStart="50dp"
                android:layout_marginLeft="50dp"
                android:layout_marginEnd="51dp"
                android:layout_marginRight="51dp"
                android:drawablePadding="5dp"
                android:ems="10"
                android:fontFamily="sans-serif-light"
                android:hint="@string/ingresar_precio_total"
                android:inputType="numberDecimal"
                android:maxLength="10"
                android:text="@string/ingresar_precio_total"
                android:textColorHint="#919191"
                android:textColor="@color/colorText"
                android:textColorLink="@color/colorAccent"
                android:textSize="18sp"
                tools:ignore="Autofill" />

            <Button
                android:id="@+id/buttonGuardar"
                android:layout_width="150dp"
                android:layout_height="35dp"
                android:layout_below="@+id/editPrecioTotal"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="40dp"
                android:background="#323232"
                android:drawableLeft="@drawable/ic_save_black_24dp"
                android:fontFamily="sans-serif-light"
                android:paddingLeft="15dp"
                android:text="@string/guardar_datos"
                android:textColor="@color/colorAccent"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/editVacio"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_below="@+id/buttonGuardar"
                android:layout_marginTop="35dp"
                android:background="#00000000"
                android:focusable="false"
                android:text=""
                android:gravity="center_horizontal"
                android:hint="@string/componentes" />

        </RelativeLayout>
    </ScrollView>
</RelativeLayout>